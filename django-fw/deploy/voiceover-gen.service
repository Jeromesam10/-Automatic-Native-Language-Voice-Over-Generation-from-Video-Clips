[Unit]
Description=Voice Over Gen Django API
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=__USER__
Group=__GROUP__
WorkingDirectory=__APP_DIR__
EnvironmentFile=__APP_DIR__/.env
ExecStart=__APP_DIR__/.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:__PORT__ --workers __WORKERS__
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
